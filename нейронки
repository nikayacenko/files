import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader
from torch.nn.utils.rnn import pad_sequence
from torchtext.datasets import IMDB
from torchtext.data.utils import get_tokenizer
from torchtext.vocab import build_vocab_from_iterator
import matplotlib.pyplot as plt
import time

# Устройство
device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Device: {device}")

# подготовка данных

tokenizer = get_tokenizer('basic_english')

train_list = list(IMDB(split='train'))
test_list = list(IMDB(split='test'))

def yield_tokens(data_iter):
    for label, line in data_iter:
        yield tokenizer(line)

# Словарь
vocab = build_vocab_from_iterator(yield_tokens(train_list), specials=['<pad>', '<unk>'], max_tokens=10000)
vocab.set_default_index(vocab['<unk>'])

MAX_LENGTH = 256
BATCH_SIZE = 64

def text_pipeline(text):
    return [vocab[token] for token in tokenizer(text)]

def label_pipeline(label):
    # IMDB возвращает 'pos'/2 для положительных
    #print(f"Label type: {type(label)}, value: {label}")
    return 1 if label == 2 else 0

def collate_batch(batch):
    labels = []
    texts = []
    for label, text in batch:
        #print(f"Raw label: {label}, type: {type(label)}")  # Отладка

        labels.append(label_pipeline(label))
        text_tensor = torch.tensor(text_pipeline(text), dtype=torch.long)
        if len(text_tensor) > MAX_LENGTH:
            text_tensor = text_tensor[:MAX_LENGTH]
        texts.append(text_tensor)
    padded_texts = pad_sequence(texts, batch_first=True, padding_value=vocab['<pad>'])
    return torch.tensor(labels, dtype=torch.float32), padded_texts

# Создание загрузчиков
train_loader = DataLoader(train_list, batch_size=BATCH_SIZE, shuffle=True, collate_fn=collate_batch)
test_loader = DataLoader(test_list, batch_size=BATCH_SIZE, shuffle=False, collate_fn=collate_batch)

print(f"Train: {len(train_list)}, Test: {len(test_list)}, Vocab: {len(vocab)}")

# реализация модели

class LSTMSentiment(nn.Module):
    def __init__(self, vocab_size, embedding_dim=128, hidden_dim=128, num_layers=2, dropout=0.5):
        super().__init__()
        self.embedding = nn.Embedding(vocab_size, embedding_dim, padding_idx=vocab['<pad>'])
        self.lstm = nn.LSTM(embedding_dim, hidden_dim, num_layers, batch_first=True, dropout=dropout,
                            bidirectional=True)
        self.dropout = nn.Dropout(dropout)
        self.fc = nn.Linear(hidden_dim * 2, 1)
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        embedded = self.embedding(x)
        lstm_out, (hidden, cell) = self.lstm(embedded)
        # Берем последние скрытые состояния последних слоев (вперед и назад)
        hidden = torch.cat((hidden[-2, :, :], hidden[-1, :, :]), dim=1)
        return self.sigmoid(self.fc(self.dropout(hidden))).squeeze()

model = LSTMSentiment(len(vocab)).to(device)
criterion = nn.BCELoss()
optimizer = optim.Adam(model.parameters(), lr=0.001)

# обучение сети

epochs = 5
train_losses, test_accuracies = [], []

for epoch in range(epochs):
    model.train()
    total_loss = 0
    for labels, texts in train_loader:
        labels, texts = labels.to(device), texts.to(device)
        optimizer.zero_grad()
        pred = model(texts)
        loss = criterion(pred, labels)
        loss.backward()
        optimizer.step()
        total_loss += loss.item()

    train_losses.append(total_loss / len(train_loader))

# Оценка качества классификации
    model.eval()
    correct = 0
    total = 0
    with torch.no_grad():
        for labels, texts in test_loader:
            labels, texts = labels.to(device), texts.to(device)
            pred = model(texts)
            correct += (torch.round(pred) == labels).sum().item()
            total += len(labels)
    acc = 100 * correct / total
    test_accuracies.append(acc)
    print(f"Epoch {epoch + 1}: Loss={train_losses[-1]:.4f}, Acc={acc:.2f}%")

plt.plot(test_accuracies)
plt.xlabel('Эпоха')
plt.ylabel('Точность (%)')
plt.title('Точность на тестовой выборке')
plt.grid(True)
plt.show()

# анализ влияния длины последовательности

print("\nВлияние длины последовательности")
lengths = [128, 256, 512]
results = []

for max_len in lengths:
    def collate_len(batch):
        labels, texts = [], []
        for label, text in batch:
            labels.append(label_pipeline(label))
            t = torch.tensor(text_pipeline(text), dtype=torch.long)
            texts.append(t[:max_len] if len(t) > max_len else t)
        return torch.tensor(labels, dtype=torch.float32), pad_sequence(texts, batch_first=True, padding_value=vocab['<pad>'])

    loader = DataLoader(test_list, batch_size=BATCH_SIZE, shuffle=False, collate_fn=collate_len)
    model.eval()
    correct, total = 0, 0
    start = time.time()
    with torch.no_grad():
        for labels, texts in loader:
            labels, texts = labels.to(device), texts.to(device)
            pred = model(texts)
            correct += (torch.round(pred) == labels).sum().item()
            total += len(labels)
    elapsed = time.time() - start
    acc = 100 * correct / total
    results.append((max_len, acc, elapsed))
    print(f"Length {max_len}: Acc={acc:.2f}%, Time={elapsed:.2f}s")

# Сравнение LSTM и GRU

print("\nравнение LSTM и GRU")
class GRUSentiment(nn.Module):
    def __init__(self, vocab_size, embedding_dim=128, hidden_dim=128, num_layers=2, dropout=0.5):
        super().__init__()
        self.embedding = nn.Embedding(vocab_size, embedding_dim, padding_idx=vocab['<pad>'])
        self.gru = nn.GRU(embedding_dim, hidden_dim, num_layers, batch_first=True, dropout=dropout, bidirectional=True)
        self.dropout = nn.Dropout(dropout)
        self.fc = nn.Linear(hidden_dim * 2, 1)
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        embedded = self.embedding(x)
        gru_out, hidden = self.gru(embedded)
        hidden = torch.cat((hidden[-2, :, :], hidden[-1, :, :]), dim=1)
        return self.sigmoid(self.fc(self.dropout(hidden))).squeeze()

gru_model = GRUSentiment(len(vocab)).to(device)
gru_optimizer = optim.Adam(gru_model.parameters(), lr=0.001)

for epoch in range(3):
    gru_model.train()
    for labels, texts in train_loader:
        labels, texts = labels.to(device), texts.to(device)
        gru_optimizer.zero_grad()
        loss = criterion(gru_model(texts), labels)
        loss.backward()
        gru_optimizer.step()

# Оценка GRU
gru_model.eval()
correct, total = 0, 0
with torch.no_grad():
    for labels, texts in test_loader:
        labels, texts = labels.to(device), texts.to(device)
        pred = gru_model(texts)
        correct += (torch.round(pred) == labels).sum().item()
        total += len(labels)
gru_acc = 100 * correct / total
print(f"LSTM точность: {test_accuracies[-1]:.2f}% | GRU точность: {gru_acc:.2f}%")

#  Анализ ошибок классификации
# Получаем длины всех отзывов и результаты предсказаний
model.eval()
text_lengths = []
predictions = []
true_labels = []

with torch.no_grad():
    for labels, texts in test_loader:
        labels, texts = labels.to(device), texts.to(device)
        pred = torch.round(model(texts)).cpu().numpy()

        # Для каждого отзыва в батче
        for i in range(len(labels)):
            # Длина отзыва (количество токенов, без паддинга)
            text = texts[i]
            # Считаем реальную длину (исключая паддинги)
            real_length = (text != vocab['<pad>']).sum().item()
            text_lengths.append(real_length)
            predictions.append(pred[i])
            true_labels.append(labels[i].cpu().item())

# Разбиваем на группы по длине
length_groups = [(0, 50), (50, 100), (100, 150), (150, 200), (200, 250), (250, 300), (300, 500)]
group_accuracies = []
group_counts = []

for min_len, max_len in length_groups:
    correct = 0
    total = 0
    for i in range(len(text_lengths)):
        if min_len <= text_lengths[i] < max_len:
            total += 1
            if predictions[i] == true_labels[i]:
                correct += 1
    if total > 0:
        acc = 100 * correct / total
        group_accuracies.append(acc)
        group_counts.append(total)
        print(f"Длина [{min_len}-{max_len}): {acc:.2f}% (всего: {total} отзывов)")
    else:
        group_accuracies.append(0)
        group_counts.append(0)
        print(f"Длина [{min_len}-{max_len}): нет отзывов")

# Построение гистограммы
plt.figure(figsize=(10, 5))

# График точности по группам
labels = [f"{l[0]}-{l[1]}" for l in length_groups]
plt.bar(labels, group_accuracies, color='skyblue', edgecolor='black')
plt.xlabel('Длина отзыва (токены)')
plt.ylabel('Точность (%)')
plt.title('Зависимость точности классификации от длины отзыва')
plt.ylim(0, 100)
for i, (acc, count) in enumerate(zip(group_accuracies, group_counts)):
    plt.text(i, acc + 1, f'{acc:.1f}%\n(n={count})', ha='center', fontsize=9)
plt.grid(axis='y')
plt.show()

